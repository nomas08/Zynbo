rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Users --------
    // Any authenticated user can read profiles (needed to render chat lists and search).
    // Each user may write only their own profile document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId;
      allow delete: if false;
    }

    // -------- Chats --------
    // A chat doc can be created by an authenticated user who is in the participants list.
    // Reads/updates are allowed only for listed participants.
    match /chats/{chatId} {
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2;

      allow read, update: if request.auth != null
                          && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // -------- Messages --------
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.senderId
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Messages are immutable.
        allow update, delete: if false;
      }
    }
  }
}
